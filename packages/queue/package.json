{
  "name": "@lara-node/queue",
  "version": "0.1.11",
  "description": "Lara-Node job queue, worker, and scheduler",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "config",
    "README.md"
  ],
  "laraNode": {
    "publish": [
      {
        "tag": "config",
        "from": "config/queue.config.ts",
        "to": "config/queue.config.ts"
      }
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@lara-node/cache": "^0.1.7",
    "@lara-node/db": "^0.1.13",
    "cron-parser": "^5.5.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "rimraf": "^6.0.1",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3",
    "@lara-node/core": "workspace:^"
  },
  "peerDependencies": {
    "@lara-node/core": "^0.1.5"
  }
}