{
  "name": "@lara-node/cache",
  "version": "0.1.2",
  "description": "Lara-Node cache manager — file, database, and Redis drivers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@lara-node/core": "workspace:^",
    "@lara-node/db": "workspace:^",
    "redis": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "rimraf": "^6.0.1",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
