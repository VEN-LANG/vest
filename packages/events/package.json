{
  "name": "@vest/events",
  "version": "0.1.0",
  "description": "Vest event dispatcher, listeners, decorators, and WebSocket broadcasting",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vest/core": "workspace:*",
    "@vest/queue": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/ws": "^8.18.1",
    "rimraf": "^6.0.1",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
