{
  "name": "@lara-node/validator",
  "version": "0.1.1",
  "description": "Laravel-inspired validation engine for Lara-Node",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --out-dir dist --dts",
    "dev": "tsdown src/index.ts --format esm --out-dir dist --dts --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lara-node/db": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "rimraf": "^6.0.1",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3"
  }
}
