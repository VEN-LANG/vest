{
  "name": "@lara-node/telescope",
  "version": "0.1.4",
  "description": "Lara-Node Telescope — request and query debug dashboard",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "config",
    "README.md"
  ],
  "laraNode": {
    "publish": [
      { "tag": "config", "from": "config/telescope.config.ts", "to": "config/telescope.config.ts" }
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@lara-node/cache": "workspace:^",
    "@lara-node/core": "workspace:^",
    "@lara-node/db": "workspace:^",
    "@lara-node/events": "workspace:^",
    "@lara-node/horizon": "workspace:^",
    "@lara-node/queue": "workspace:^",
    "@lara-node/router": "workspace:^",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "rimraf": "^6.0.1",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
