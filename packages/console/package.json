{
  "name": "@lara-node/console",
  "version": "0.1.5",
  "description": "Lara-Node Artisan CLI — commands, kernel, and scheduler",
  "bin": {
    "artisan": "./dist/artisan.js"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./artisan": "./dist/artisan.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@lara-node/cache": "workspace:^",
    "@lara-node/core": "workspace:^",
    "@lara-node/db": "workspace:^",
    "@lara-node/events": "workspace:^",
    "@lara-node/horizon": "workspace:^",
    "@lara-node/queue": "workspace:^",
    "@lara-node/router": "workspace:^",
    "dotenv": "^17.2.3",
    "reflect-metadata": "^0.2.2",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/yargs": "^17.0.35",
    "rimraf": "^6.0.1",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
