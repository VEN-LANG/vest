{
  "name": "@vest-ts/console",
  "version": "0.1.0",
  "description": "Vest Artisan CLI — commands, kernel, and scheduler",
  "bin": {
    "artisan": "./dist/artisan.js"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./artisan": "./dist/artisan.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vest-ts/cache": "workspace:*",
    "@vest-ts/core": "workspace:*",
    "@vest-ts/db": "workspace:*",
    "@vest-ts/events": "workspace:*",
    "@vest-ts/horizon": "workspace:*",
    "@vest-ts/queue": "workspace:*",
    "@vest-ts/router": "workspace:*",
    "dotenv": "^17.2.3",
    "reflect-metadata": "^0.2.2",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/yargs": "^17.0.35",
    "rimraf": "^6.0.1",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
