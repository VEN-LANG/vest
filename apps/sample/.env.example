APP_NAME="Vest Sample"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
PORT=3001

# Database — MongoDB (default) or MySQL
DB_CONNECTION=mongodb
DB_HOST=127.0.0.1
DB_PORT=27017
DB_NAME=vest_sample

# Cache
CACHE_DRIVER=file

# Queue (sync = in-process, no worker needed)
QUEUE_CONNECTION=sync

# Mail (log = printed to console)
MAIL_DRIVER=log

# JWT
JWT_SECRET=change-me-in-production

# Telescope dashboard (optional)
TELESCOPE_ENABLED=true
# TELESCOPE_TOKEN=secret
