{
  "name": "@lara-node/lara-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -r @swc-node/register -r tsconfig-paths/register -r ./src/register.ts src/server.ts",
    "start": "node dist/server.js",
    "build": "tsdown src/server.ts src/artisan.ts --format cjs --out-dir dist",
    "artisan": "node -r @swc-node/register -r tsconfig-paths/register -r ./src/register.ts src/artisan.ts",
    "migrate": "node -r @swc-node/register -r tsconfig-paths/register -r ./src/register.ts src/artisan.ts migrate",
    "migrate:fresh": "node -r @swc-node/register -r tsconfig-paths/register -r ./src/register.ts src/artisan.ts migrate:fresh",
    "db:seed": "node -r @swc-node/register -r tsconfig-paths/register -r ./src/register.ts src/artisan.ts db:seed",
    "test": "vitest run",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lara-node/auth": "workspace:^",
    "@lara-node/cache": "workspace:^",
    "@lara-node/console": "workspace:^",
    "@lara-node/core": "workspace:^",
    "@lara-node/db": "workspace:^",
    "@lara-node/events": "workspace:^",
    "@lara-node/horizon": "workspace:^",
    "@lara-node/mail": "workspace:^",
    "@lara-node/middlewares": "workspace:^",
    "@lara-node/queue": "workspace:^",
    "@lara-node/router": "workspace:^",
    "@lara-node/telescope": "workspace:^",
    "@lara-node/validator": "workspace:^",
    "reflect-metadata": "^0.2.2",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^3.0.2",
    "multer": "^2.0.1",
    "yargs": "^18.0.0",
    "mongodb": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.12",
    "@types/yargs": "^17.0.33",
    "@swc-node/register": "^1.10.9",
    "@swc/core": "^1.11.0",
    "tsconfig-paths": "^4.2.0",
    "oxlint": "^0.16.6",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
