{
  "name": "@vest/example",
  "version": "0.1.0",
  "private": true,
  "description": "Vest example API application",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsdown src/server.ts src/artisan.ts --format esm --out-dir dist",
    "artisan": "tsx src/artisan.ts",
    "migrate": "tsx src/artisan.ts migrate",
    "migrate:fresh": "tsx src/artisan.ts migrate:fresh",
    "db:seed": "tsx src/artisan.ts db:seed",
    "key:generate": "tsx src/artisan.ts key:generate",
    "route:list": "tsx src/artisan.ts route:list",
    "queue:work": "tsx src/artisan.ts queue:work",
    "test": "vitest run",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/yargs": "^17.0.35",
    "@vest/auth": "workspace:*",
    "@vest/cache": "workspace:*",
    "@vest/console": "workspace:*",
    "@vest/core": "workspace:*",
    "@vest/db": "workspace:*",
    "@vest/events": "workspace:*",
    "@vest/horizon": "workspace:*",
    "@vest/mail": "workspace:*",
    "@vest/queue": "workspace:*",
    "@vest/router": "workspace:*",
    "@vest/telescope": "workspace:*",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "multer": "2.0.2",
    "mysql2": "^3.16.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.33.5",
    "ws": "^8.19.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.12.2",
    "@types/ws": "^8.18.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^0.16.6",
    "tsdown": "^0.12.9",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
