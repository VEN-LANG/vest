{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@config/*": ["src/config/*"],
      "@database/*": ["src/database/*"],
      "@routes/*": ["src/routes/*"],
      "@bootstrap/*": ["src/bootstrap/*"],
      "@vest-ts/core": ["../../packages/core/src/index.ts"],
      "@vest-ts/db": ["../../packages/db/src/index.ts"],
      "@vest-ts/cache": ["../../packages/cache/src/index.ts"],
      "@vest-ts/events": ["../../packages/events/src/index.ts"],
      "@vest-ts/queue": ["../../packages/queue/src/index.ts"],
      "@vest-ts/mail": ["../../packages/mail/src/index.ts"],
      "@vest-ts/router": ["../../packages/router/src/index.ts"],
      "@vest-ts/auth": ["../../packages/auth/src/index.ts"],
      "@vest-ts/console": ["../../packages/console/src/index.ts"],
      "@vest-ts/horizon": ["../../packages/horizon/src/index.ts"],
      "@vest-ts/telescope": ["../../packages/telescope/src/index.ts"]
    }
  },
  "include": ["src", "config"],
  "exclude": ["dist", "node_modules"]
}
