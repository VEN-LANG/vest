{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@config/*": ["src/config/*"],
      "@database/*": ["src/database/*"],
      "@routes/*": ["src/routes/*"],
      "@bootstrap/*": ["src/bootstrap/*"],
      "@lara-node/core": ["../../packages/core/src/index.ts"],
      "@lara-node/db": ["../../packages/db/src/index.ts"],
      "@lara-node/cache": ["../../packages/cache/src/index.ts"],
      "@lara-node/events": ["../../packages/events/src/index.ts"],
      "@lara-node/queue": ["../../packages/queue/src/index.ts"],
      "@lara-node/mail": ["../../packages/mail/src/index.ts"],
      "@lara-node/router": ["../../packages/router/src/index.ts"],
      "@lara-node/auth": ["../../packages/auth/src/index.ts"],
      "@lara-node/console": ["../../packages/console/src/index.ts"],
      "@lara-node/horizon": ["../../packages/horizon/src/index.ts"],
      "@lara-node/telescope": ["../../packages/telescope/src/index.ts"]
    }
  },
  "include": ["src", "config"],
  "exclude": ["dist", "node_modules"]
}
